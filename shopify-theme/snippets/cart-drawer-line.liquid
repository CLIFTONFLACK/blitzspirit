{% comment %}
  cart-drawer-line — one SYSTEM_LEDGER line item (cart drawer).

  Params:
    item: {Object} line_item (required)

  cart.js hooks: [data-line-item][data-line-key] on the row,
  [data-qty-change][data-line-key] on the stepper buttons,
  [data-line-qty] on the quantity readout,
  [data-remove][data-line-key] on the remove button.

  Money is server-formatted via the price snippet — never in JS.

  Usage:
    {% render 'cart-drawer-line', item: item %}
{% endcomment %}

<div class="cart-row" data-line-item data-line-key="{{ item.key }}">
  <a href="{{ item.url }}" class="ci-plate" tabindex="-1" aria-hidden="true">
    {%- if item.image != blank -%}
      {%- assign thumb_h = 128 | divided_by: item.image.aspect_ratio | round -%}
      <img
        src="{{ item.image | image_url: width: 128 }}"
        srcset="{{ item.image | image_url: width: 128 }} 1x, {{ item.image | image_url: width: 256 }} 2x"
        alt=""
        width="128"
        height="{{ thumb_h }}"
        loading="lazy"
      >
    {%- endif -%}
  </a>

  <div class="ci-body">
    <div class="ci-name"><a href="{{ item.url }}">{{ item.product.title | escape }}</a></div>
    {%- unless item.product.has_only_default_variant -%}
      <div class="ci-meta">
        {%- for option in item.options_with_values -%}
          {{- option.name | upcase | escape }}: {{ option.value | upcase | escape }}{% unless forloop.last %} / {% endunless -%}
        {%- endfor -%}
      </div>
    {%- endunless -%}
    <div class="ci-controls">
      <div class="ci-qty">
        <button type="button" class="ci-qty-btn snap" data-qty-change="-1" data-line-key="{{ item.key }}" aria-label="{{ 'cart.quantity' | t }} -1">&minus;</button>
        <span class="ci-qty-val" data-line-qty>{{ item.quantity }}</span>
        <button type="button" class="ci-qty-btn snap" data-qty-change="1" data-line-key="{{ item.key }}" aria-label="{{ 'cart.quantity' | t }} +1">+</button>
      </div>
      <span class="ci-price">{% render 'price', price: item.final_line_price %}</span>
    </div>
  </div>

  <button type="button" class="ci-rm snap" data-remove data-line-key="{{ item.key }}">[ {{ 'cart.remove' | t }} ]</button>
</div>
