{% comment %}
  main-password — the locked-door splash (layout/password.liquid).
  Sticker, chunk headline, storefront password form, and a Home Guard
  waitlist via the shared newsletter-form snippet.
{% endcomment %}

<div class="main-password" data-section-id="{{ section.id }}">
  <div class="main-password-inner">
    {%- if section.settings.sticker != blank -%}
      <img
        class="main-password-sticker"
        src="{{ section.settings.sticker | image_url: width: 600 }}"
        alt="{{ section.settings.sticker.alt | default: shop.name | escape }}"
        width="{{ section.settings.sticker.width }}"
        height="{{ section.settings.sticker.height }}"
        loading="eager"
      >
    {%- else -%}
      <img
        class="main-password-sticker"
        src="{{ 'blitzspirit-sticker.png' | asset_url }}"
        alt="{{ shop.name | escape }}"
        width="585"
        height="250"
        loading="eager"
      >
    {%- endif -%}

    <p class="led-index tag">[ {{ 'general.password_page.opening_soon' | t }} ]</p>

    <h1 class="chunk main-password-head">{{ section.settings.heading | escape }}</h1>

    {%- if section.settings.body != blank -%}
      <p class="main-password-body">{{ section.settings.body | escape }}</p>
    {%- endif -%}

    {% render 'newsletter-form',
      id: 'PasswordWaitlist',
      button_label: section.settings.button_label
    %}

    <details class="main-password-gate">
      <summary class="tag main-password-gate-toggle">[ {{ 'general.password_page.login_form_heading' | t }} ]</summary>
      {%- form 'storefront_password', class: 'main-password-form' -%}
        {%- if form.errors -%}
          <p class="tag main-password-error" role="alert">[ {{ 'general.password_page.login_form_error' | t }} ]</p>
        {%- endif -%}
        <label class="visually-hidden" for="Password">{{ 'general.password_page.login_form_password_label' | t }}</label>
        <div class="nws-row">
          <input
            class="nws-input"
            type="password"
            name="password"
            id="Password"
            autocomplete="current-password"
            placeholder="{{ 'general.password_page.login_form_password_placeholder' | t }}"
            required
          >
          <button type="submit" class="nws-submit snap">[ {{ 'general.password_page.login_form_submit' | t }} ]</button>
        </div>
      {%- endform -%}
    </details>

    <p class="tag tag-mute main-password-admin">{{ 'general.password_page.admin_link_html' | t }}</p>
  </div>
</div>

{% stylesheet %}
.main-password {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--s5) var(--s3);
  background:
    linear-gradient(rgba(10, 10, 10, 0.72), rgba(10, 10, 10, 0.84)),
    var(--tex-char) center/cover no-repeat;
}
.main-password-inner {
  width: 100%;
  max-width: 520px;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--s3);
  text-align: center;
}
.main-password-sticker { width: min(64%, 300px); height: auto; filter: drop-shadow(2px 4px 10px rgba(0, 0, 0, 0.85)); }
.main-password-head { color: #fff; font-size: clamp(2.4rem, 8vw, 4.5rem); line-height: 0.92; }
.main-password-body {
  color: var(--bone-dim);
  font-size: 12px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  line-height: 1.75;
  max-width: 44ch;
}
.main-password .nlf { width: 100%; }
.main-password-gate { width: 100%; margin-top: var(--s2); }
.main-password-gate-toggle { cursor: pointer; list-style: none; color: var(--bone-mute); }
.main-password-gate-toggle::-webkit-details-marker { display: none; }
.main-password-gate-toggle:hover { color: var(--bone); }
.main-password-gate[open] .main-password-gate-toggle { color: var(--bone); }
.main-password-form { margin-top: var(--s2); }
.main-password-error { color: var(--signal); margin-bottom: var(--s1); }
.main-password-admin a { border-bottom: 1px solid var(--line-bri); }
.main-password-admin a:hover { color: var(--bone); }
{% endstylesheet %}

{% schema %}
{
  "name": "Password",
  "settings": [
    {
      "type": "image_picker",
      "id": "sticker",
      "label": "Sticker / logo",
      "info": "Leave empty to use the bundled BlitzSpirit sticker."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NOT OPEN YET."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Copy",
      "default": "ISSUE_001 is being prepared behind this door. Leave your email and you’ll be first through it — plus 10% off your first order."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Waitlist button label",
      "default": "[ SIGN UP ]"
    }
  ]
}
{% endschema %}
