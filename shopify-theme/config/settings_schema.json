        "label": "Line (borders)",
        "default": "#2a2a2a"
      },
      {
        "type": "color",
        "id": "color_line_bri",
        "label": "Line bright",
        "default": "#3a3a3a"
      },
      {
        "type": "color",
        "id": "color_bone",
        "label": "Bone (body text)",
        "default": "#ECECEC"
