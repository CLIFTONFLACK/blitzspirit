{% layout none %}

{%- liquid
  assign formatted_initial_value = gift_card.initial_value | money_without_trailing_zeros
-%}

<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="referrer" content="origin">
    <meta name="robots" content="noindex, nofollow">
    <meta name="theme-color" content="{{ settings.color_ink | default: '#0A0A0A' }}">

    <title>{{ 'gift_cards.issued.title' | t: value: formatted_initial_value, shop: shop.name }}</title>

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}

    {{ content_for_header }}

    {% render 'css-variables' %}
    {{ 'theme.css' | asset_url | stylesheet_tag }}

    <style>
      .gc-main {
        max-width: 560px;
        margin: 0 auto;
        min-height: 100vh;
        padding: var(--s6) var(--s3);
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: var(--s3);
        text-align: center;
      }
      .gc-frame {
        position: relative;
        border: 1px solid var(--line-bri);
        background: var(--panel);
        padding: var(--s5) var(--s4);
        display: flex;
        flex-direction: column;
        gap: var(--s3);
        align-items: center;
      }
      .gc-tick { position: absolute; width: 14px; height: 14px; border: 2px solid var(--signal); }
      .gc-tick--tl { top: 10px; left: 10px; border-right: none; border-bottom: none; }
      .gc-tick--br { bottom: 10px; right: 10px; border-left: none; border-top: none; }
      .gc-shop { color: #fff; font-size: clamp(1.6rem, 6vw, 2.4rem); }
      .gc-value { font-size: clamp(2.4rem, 10vw, 4rem); color: var(--bone); line-height: 0.95; }
      .gc-expired { color: var(--signal); }
      .gc-balance { color: var(--bone-mute); }
      .gc-code-panel { width: 100%; }
      .gc-code-panel .fm-row { grid-template-columns: 90px 1fr; align-items: center; }
      .gc-code-panel .fm-val { color: #fff; font-size: 14px; letter-spacing: 0.2em; user-select: all; }
      .gc-copy {
        border: 1px solid var(--line-bri);
        padding: 10px 16px;
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--bone);
      }
      .gc-copy:hover { border-color: var(--bone); color: #fff; }
      .gc-copy-status { min-height: 16px; color: var(--signal); }
      .gc-qr { display: flex; justify-content: center; background: var(--plate); border: 1px solid #000; padding: 12px; }
      .gc-wallet img { margin: 0 auto; }
      .gc-shop-link { text-decoration: none; }
      @media print {
        body { background: #fff; color: #000; }
        .gc-copy, .gc-shop-link { display: none; }
      }
    </style>
  </head>

  <body class="gift-card-page">
    <main id="MainContent" role="main" class="gc-main">
      <p class="tag tag-mute">[ {{ 'gift_cards.issued.subtext' | t | upcase }} // ASSET_TRANSFER ]</p>

      <div class="gc-frame">
        <span class="gc-tick gc-tick--tl" aria-hidden="true"></span>
        <span class="gc-tick gc-tick--br" aria-hidden="true"></span>

        <h1 class="chunk gc-shop">{{ shop.name }}</h1>
        <p class="chunk gc-value">{{ gift_card.initial_value | money }}</p>

        {%- if gift_card.enabled == false or gift_card.expired -%}
          <p class="tag gc-expired">[ {{ 'gift_cards.issued.expired' | t }} ]</p>
        {%- endif -%}

        {%- if gift_card.balance != gift_card.initial_value -%}
          <p class="tag gc-balance">{{ gift_card.balance | money }}</p>
        {%- endif -%}

        <div class="field-manual gc-code-panel">
          <div class="fm-head tag">[ {{ 'gift_cards.issued.gift_card_code' | t | upcase }} ]</div>
          <div class="fm-row">
            <span class="fm-key">CODE</span>
            <span class="fm-val" data-gift-card-code>{{ gift_card.code | format_code }}</span>
          </div>
          {%- if gift_card.expires_on -%}
            {%- assign gift_card_expiration_date = gift_card.expires_on | date: '%d/%m/%Y' -%}
            <div class="fm-row">
              <span class="fm-key">EXPIRY</span>
              <span class="fm-val">{{ 'gift_cards.issued.expiration_date' | t: expires_on: gift_card_expiration_date }}</span>
            </div>
          {%- endif -%}
        </div>

        <button type="button" class="gc-copy snap" data-copy-code hidden>
          [ {{ 'gift_cards.issued.copy_code' | t }} ]
        </button>
        <p class="tag gc-copy-status" data-copy-status role="status" aria-live="polite"></p>

        <div
          class="gc-qr"
          data-gift-card-qr
          data-identifier="{{ gift_card.qr_identifier }}"
        ></div>

        {%- if gift_card.pass_url -%}
          <a href="{{ gift_card.pass_url }}" class="tag gc-wallet">
            <img
              src="{{ 'gift-card/add-to-apple-wallet.svg' | shopify_asset_url }}"
              width="120"
              height="40"
              alt="{{ 'gift_cards.issued.qr_image_alt' | t }}"
              loading="lazy"
            >
          </a>
        {%- endif -%}
      </div>

      <a href="{{ shop.url }}" class="directive snap gc-shop-link" target="_blank" rel="noopener">
        [ {{ 'gift_cards.issued.shop_link' | t }} ]
      </a>
    </main>

    <script src="{{ 'vendor/qrcode.js' | shopify_asset_url }}" defer></script>
    <script>
      window.addEventListener('DOMContentLoaded', function () {
        var qr = document.querySelector('[data-gift-card-qr]');
        if (qr && window.QRCode) {
          new window.QRCode(qr, {
            text: qr.dataset.identifier,
            width: 120,
            height: 120
          });
        }

        var copyBtn = document.querySelector('[data-copy-code]');
        var codeEl = document.querySelector('[data-gift-card-code]');
        var statusEl = document.querySelector('[data-copy-status]');
        if (copyBtn && codeEl && navigator.clipboard) {
          copyBtn.hidden = false;
          copyBtn.addEventListener('click', function () {
            navigator.clipboard.writeText(codeEl.textContent.trim()).then(function () {
              if (statusEl) statusEl.textContent = '[ COPIED ]';
            });
          });
        }
      });
    </script>
  </body>
</html>
